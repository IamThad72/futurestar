# Copy to .env and fill in real values.
#
# SECURITY: Never commit .env to git. It contains secrets.
# - .env is in .gitignore
# - Use .env.example as a template (no real values)
# - In production, use your platform's secrets (Vercel, Railway, etc.)
# Required for Supabase (primary database)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase API (auth, storage, etc.)
SUPABASE_URL=<SUBSTITUTE_SUPABASE_URL>
SUPABASE_PUBLISHABLE_KEY=<SUBSTITUTE_SUPABASE_PUBLISHABLE_KEY>
SUPABASE_DB_PASSWORD=your_database_password

# Optional: direct connection for migrations
SUPABASE_DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Native app (Capacitor): URL of your deployed Nuxt/Nitro API (no trailing slash).
# Required for cap:sync / build:mobile:* — baked into the static app as runtimeConfig.public.apiBase.
# Mobile builds set NUXT_CAPACITOR=true automatically (hash routing). Do not run plain `nuxt generate` for Android/iOS.
# Android emulator + npm run dev on host:
#   NUXT_PUBLIC_API_BASE=http://10.0.2.2:3000
# iOS simulator + npm run dev on host:
#   NUXT_PUBLIC_API_BASE=http://localhost:3000
# Production:
#   NUXT_PUBLIC_API_BASE=https://your-deployed-app.example.com
NUXT_PUBLIC_API_BASE=

# Deployed web app URL (optional; added to API CORS allowlist)
# NUXT_PUBLIC_SITE_URL=https://your-app.example.com

# Extra CORS origins for API (comma-separated, optional)
# CORS_ORIGINS=https://your-app.example.com

# Optional: local PostgreSQL (only for migrate-to-supabase.ps1 source)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estate_mgmt_db
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
